# ═══════════════════════════════════════════════════════════════
# SwiftDeploy (轻舟) Environment Configuration
# ═══════════════════════════════════════════════════════════════

# ── Server ──────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=3000

# Database: SQLite (dev) or PostgreSQL (prod)
DATABASE_URL=sqlite:///data/swiftdeploy.db
# DATABASE_URL=postgresql://swiftdeploy:swiftdeploy@localhost:5432/swiftdeploy

JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=24h
LOG_LEVEL=debug

# ── gRPC ────────────────────────────────────────────────────
GRPC_HOST=localhost
GRPC_PORT=50051

# ── Electron Desktop ────────────────────────────────────────
# NestJS backend URL for IPC proxy
BACKEND_URL=http://localhost:3000

# ── Infrastructure ──────────────────────────────────────────
DNSMASQ_DHCP_RANGE=192.168.1.100,192.168.1.200
PXE_SERVER_IP=192.168.1.10
TFTP_ROOT=/srv/tftp
PXE_BOOT_URL=http://192.168.1.10:80/pxe/

# ── PostgreSQL (Production) ─────────────────────────────────
# POSTGRES_USER=swiftdeploy
# POSTGRES_PASSWORD=swiftdeploy
# POSTGRES_DB=swiftdeploy
# POSTGRES_HOST=postgres
# POSTGRES_PORT=5432

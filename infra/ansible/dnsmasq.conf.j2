# SwiftDeploy dnsmasq configuration
port=53
domain-needed
bogus-priv
no-resolv
server={{ dns_server }}

# DHCP
dhcp-range={{ dhcp_range }}
dhcp-option=3,{{ pxe_server }}
dhcp-option=6,{{ dns_server }}
dhcp-authoritative
enable-tftp
tftp-root=/srv/tftp

# PXE boot
dhcp-boot=pxelinux.0,pxeserver,{{ pxe_server }}

# Logging
log-queries
log-dhcp
